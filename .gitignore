# build
node_modules/
# Cloudflare Pages output (rebuilt on deploy)
dist/
# transient build intermediates
build/build_src.tsx
build/app.js

# runtime data (never commit factory data / secrets)
# server's storage unit: stops/production/sessions store + auto-generated token
server/data/
# legacy locations (pre-storage-folder), still ignored
server/stoptrack-data.json
server/stoptrack-token.txt
server/node_modules/
# gateway FileSink output / demo events
*.jsonl

# python
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/

# machine-specific / local (absolute Node path, per-machine)
.claude/launch.json
.venv/
.env

# os / editor
.DS_Store
Thumbs.db
*.swp
