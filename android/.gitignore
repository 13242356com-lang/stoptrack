# Gradle / Android build outputs — never commit these.
.gradle/
build/
*/build/
local.properties
.idea/
*.iml
.DS_Store
captures/
.externalNativeBuild/
.cxx/

# Generated at build time by :mobile's prepareWebAsset task (bundled web app).
mobile/src/main/assets/index.html

# Keystores / signing — never commit secrets.
*.jks
*.keystore
keystore.properties
# Exception: the shared sideload/debug key MUST be committed so phone + watch
# sign identically (Wear Data Layer requirement). Not a Play production key.
!keystore/stoptrack-debug.jks
