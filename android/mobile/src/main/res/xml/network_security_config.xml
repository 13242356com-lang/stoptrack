<?xml version="1.0" encoding="utf-8"?>
<!-- Cleartext (plain http) is permitted so the app can reach:
       • its own in-app bridge on http://127.0.0.1, and
       • a factory-LAN StopTrack server (http://192.168.x.x:4000).
     Anywhere-mode access goes over https (Cloudflare Tunnel), unaffected. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
