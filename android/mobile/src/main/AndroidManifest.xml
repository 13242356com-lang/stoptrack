<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- INTERNET: open the loopback sync socket + the optional remote forward. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Keep the bridge alive (local server + watch link) as a foreground service.
         dataSync has no hardware prerequisite, so startForeground() can't be
         refused at launch the way the connectedDevice type can on Android 14. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Floating "quick stop" bubble that hovers over other apps (Shazam-style).
         Granted once per phone via Settings → Display over other apps. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:name=".CompanionApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.StopTrackCompanion">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Watch-bridge plumbing (local port + optional remote forward). Opened
             from the persistent notification; not a launcher entry. -->
        <activity
            android:name=".BridgeSettingsActivity"
            android:exported="false"
            android:label="@string/bridge_settings_title" />

        <!-- Foreground bridge: hosts the local sync server + remote forwarder. -->
        <service
            android:name=".CompanionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Shows the stack trace on screen if the app crashes (own process so it
             survives the crashing one). Nothing fails silently. -->
        <activity
            android:name=".CrashActivity"
            android:exported="false"
            android:process=":crash"
            android:launchMode="singleTask"
            android:excludeFromRecents="true" />

        <!-- Receives stops and config requests from the watch. -->
        <service
            android:name=".WearListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/stoptrack" />
            </intent-filter>
        </service>

    </application>

</manifest>
